# ============================================
# InvoiceGhost Project - .gitignore
# ============================================

# ============================================
# Project Development Files
# ============================================
AGENTS.md
MVP_PLAN.md
.opencode/

# ============================================
# Python - Byte-compiled / optimized / DLL files
# ============================================
__pycache__/
*.py[cod]
*$py.class

# ============================================
# Python - C extensions
# ============================================
*.so

# ============================================
# Python - Distribution / packaging
# ============================================
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ============================================
# Python - Virtual environments
# ============================================
venv/
env/
ENV/
.venv

# ============================================
# Node.js / Frontend - Dependencies
# ============================================
node_modules/

# ============================================
# Next.js / Frontend - Build outputs
# ============================================
.next/
out/
.turbo/
.vercel/

# ============================================
# Node.js - Logs
# ============================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ============================================
# Environment files
# ============================================
.env
.env.local
.env.*.local
.env.production
.env.development

# ============================================
# IDE - VS Code
# ============================================
.vscode/

# ============================================
# IDE - JetBrains / IntelliJ
# ============================================
.idea/

# ============================================
# IDE - Vim
# ============================================
*.swp
*.swo
*~

# ============================================
# OS - macOS
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# ============================================
# OS - Windows
# ============================================
ehthumbs.db
Thumbs.db

# ============================================
# Testing - Python
# ============================================
.pytest_cache/
.coverage
htmlcov/
*.cover
.hypothesis/

# ============================================
# Temporary files
# ============================================
*.tmp
*.temp

# ============================================
# Documentation builds
# ============================================
docs/_build/
site/

# ============================================
# Backup files
# ============================================
*.bak
*.backup
*~

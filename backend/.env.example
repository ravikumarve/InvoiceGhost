# ============================================
# InvoiceGhost Backend Environment Variables
# ============================================
# Copy this file to .env and fill in the actual values
# NEVER commit .env to version control

# ============================================
# AI API Keys
# ============================================

# Google Gemini Flash API Key (Primary AI model)
# Get your API key from: https://makersuite.google.com/app/apikey
# Used for invoice data extraction with high accuracy
GEMINI_API_KEY=

# Groq API Key (Fallback AI model)
# Get your API key from: https://console.groq.com/keys
# Used as fallback when Gemini API fails or times out
GROQ_API_KEY=

# ============================================
# File Upload Configuration
# ============================================

# Maximum file size in MB
# Default: 10 (Recommended: 5-20 for balance between UX and server load)
MAX_FILE_SIZE_MB=10

# Allowed file extensions (comma-separated, no spaces)
# Supported formats: PDF, PNG, JPG, JPEG, WEBP
ALLOWED_EXTENSIONS=pdf,png,jpg,jpeg,webp

# ============================================
# Rate Limiting
# ============================================

# Rate limit per IP address per minute
# Default: 10 (Adjust based on your server capacity)
# Prevents abuse and ensures fair usage
RATE_LIMIT_PER_MINUTE=10

# ============================================
# Security & Authentication
# ============================================

# HMAC Secret for License Key Validation
# Generate with: openssl rand -hex 32
# Used to validate Gumroad license keys locally without database
# IMPORTANT: Keep this secret! Never share or commit to version control
LICENSE_KEY_HMAC_SECRET=

# ============================================
# CORS Configuration
# ============================================

# Frontend URL for CORS (Cross-Origin Resource Sharing)
# Set to your production frontend URL (e.g., https://invoiceghost.com)
# For local development: http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ============================================
# AI Model Configuration
# ============================================

# Temperature for AI model (0.0 - 1.0)
# Lower values (0.0-0.3) = More deterministic, focused output
# Higher values (0.7-1.0) = More creative, varied output
# Default: 0.3 (Recommended for structured data extraction)
TEMPERATURE=0.3

# Maximum retry attempts for AI API calls
# Default: 2 (Recommended: 2-3 for reliability without excessive delays)
MAX_RETRIES=2

# ============================================
# Logging Configuration
# ============================================

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# Default: INFO (Use DEBUG for development, INFO for production)
LOG_LEVEL=INFO

# ============================================
# Security Notes
# ============================================
#
# 1. NEVER commit .env to version control
# 2. Use strong, randomly generated secrets
# 3. Rotate API keys periodically
# 4. Monitor API usage for unusual activity
# 5. Keep backup of secrets in secure password manager
#
# ============================================
# Development Setup
# ============================================
#
# 1. Copy this file: cp .env.example .env
# 2. Generate HMAC secret: openssl rand -hex 32
# 3. Get API keys from respective providers
# 4. Fill in all required values in .env
# 5. Restart the application
#
# ============================================

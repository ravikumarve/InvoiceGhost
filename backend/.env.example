# InvoiceGhost Backend Environment Variables

# API Keys
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# File Processing
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=pdf,png,jpg,jpeg,webp

# Rate Limiting
RATE_LIMIT_PER_MINUTE=10

# Security
LICENSE_KEY_HMAC_SECRET=generate_with_openssl_rand_hex_32

# Server Configuration
PORT=8000
ENVIRONMENT=production

# CORS
FRONTEND_URL=https://invoiceghost.vercel.app
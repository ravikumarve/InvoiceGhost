# ============================================
# InvoiceGhost Backend — Environment Variables
# Copy this file to .env and fill in the values
# ============================================

# AI API Keys (required for extraction)
GEMINI_API_KEY=
GROQ_API_KEY=

# File Upload Limits
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=pdf,png,jpg,jpeg,webp

# Rate Limiting
RATE_LIMIT_PER_MINUTE=10

# License Key Validation (generate with: openssl rand -hex 32)
LICENSE_KEY_HMAC_SECRET=

# CORS — comma-separated frontend origins
FRONTEND_URL=http://localhost:3000

# Environment (set to "production" on Render)
ENVIRONMENT=development

# Test Mode (set to "1" only during pytest)
TESTING=
